<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>
    {% if page_title != blank %}
      {{ page_title }}
      {% if current_tags %} &mdash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
      {% if current_page != 1 %} &mdash; Page {{ current_page }}{% endif %}
      {% unless page_title contains shop.name %} &mdash; {{ shop.name }}{% endunless %}
    {% else %}
      {{ shop.name }}
    {% endif %}
  </title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  {{ content_for_header }}
  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>
<body>

  <header class="site-header">
    <div class="wrap site-header__inner">
      <a href="/" class="site-header__brand" aria-label="{{ shop.name }} home">
        <img src="{{ 'avrrio-logo.png' | asset_url }}" alt="Avrrio" class="site-header__logo">
      </a>
      <nav class="site-header__nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/pages/about">About</a>
        <a href="/pages/future">Future</a>
        <a href="/collections/avrrio-coffee">Catalog</a>
      </nav>
    </div>
  </header>

  <main id="MainContent">
    {{ content_for_layout }}
  </main>

  <footer class="site-footer">
    <div class="wrap site-footer__inner">
      <a href="/" class="site-footer__brand" aria-label="{{ shop.name }} home">
        <img src="{{ 'avrrio-logo.png' | asset_url }}" alt="Avrrio" class="site-footer__logo">
      </a>
      <p class="site-footer__copy">&copy; 2026 Avrrio. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>
