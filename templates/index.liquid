{% assign featured_collection = collections['avrrio-coffee'] %}
{% assign featured_product = featured_collection.products.first %}
{% if featured_product == blank %}
  {% assign featured_product = all_products['avrrio-french-roast'] %}
{% endif %}

<div class="home-wrap">
  <section class="home-hero">

    <div class="home-hero__content">
      <p class="home-hero__eyebrow">AVRRIO</p>
      <h1 class="home-hero__title">Simple. Strong. Daily Fuel.</h1>
      <p class="home-hero__text">
        Avrrio builds clean, reliable products designed to power your day.
        We start with coffee &mdash; and expand into energy and focus essentials.
      </p>
      <div class="home-hero__actions">
        <a href="/collections/avrrio-coffee" class="btn">Shop</a>
        {% if featured_product %}
          <a href="{{ featured_product.url }}" class="btn btn--secondary">View Product</a>
        {% endif %}
      </div>
    </div>

    <div class="home-hero__product">
      <article class="product-card">
        <div class="product-card__media">
          {% if featured_product and featured_product.featured_image %}
            <img
              src="{{ featured_product.featured_image | image_url: width: 800 }}"
              alt="{{ featured_product.featured_image.alt | default: featured_product.title | escape }}"
              class="product-card__image"
              loading="lazy"
            >
          {% else %}
            <div class="product-card__placeholder">Product image coming soon</div>
          {% endif %}
        </div>
        <div class="product-card__body">
          <p class="product-card__label">Our first product</p>
          {% if featured_product %}
            <h2 class="product-card__title">{{ featured_product.title }}</h2>
            <p class="product-card__desc">
              A clean, reliable daily product designed to become part of your routine.
            </p>
            <p class="product-card__price">{{ featured_product.price | money }}</p>
            <a href="{{ featured_product.url }}" class="btn btn--full">View Product</a>
          {% else %}
            <h2 class="product-card__title">Coming soon</h2>
            <p class="product-card__desc">
              Add a product to the avrrio-coffee collection and it will appear here automatically.
            </p>
          {% endif %}
        </div>
      </article>
    </div>

  </section>
</div>
