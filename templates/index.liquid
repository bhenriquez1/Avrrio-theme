{% assign featured_collection = collections['avrrio-coffee'] %}
{% assign featured_product = featured_collection.products.first %}

{% if featured_product == blank %}
  {% assign featured_product = all_products['avrrio-french-roast'] %}
{% endif %}

<main class="av-home">
  <div class="av-container">

    <section class="av-hero">
      <div class="av-hero__content">
        <p class="av-eyebrow">AVRRIO</p>
        <h1 class="av-hero__title">Simple. Strong. Daily Fuel.</h1>
        <p class="av-hero__text">
          Avrrio starts with one thing done right — a dependable daily product.
          Clean, consistent, and built for people who value quality without complication.
        </p>

        <div class="av-hero__actions">
          <a href="/collections/avrrio-coffee" class="av-btn av-btn--primary">Shop</a>
          {% if featured_product %}
            <a href="{{ featured_product.url }}" class="av-btn av-btn--secondary">View Product</a>
          {% endif %}
        </div>
      </div>

      <div class="av-hero__product">
        <div class="av-product-card">
          <div class="av-product-card__image-wrap">
            {% if featured_product and featured_product.featured_image %}
              <img
                src="{{ featured_product.featured_image | image_url: width: 1200 }}"
                alt="{{ featured_product.title | escape }}"
                class="av-product-card__image"
              >
            {% else %}
              <div class="av-product-card__placeholder">Product image</div>
            {% endif %}
          </div>

          <div class="av-product-card__body">
            {% if featured_product %}
              <p class="av-product-card__label">Our first product</p>
              <h2 class="av-product-card__title">{{ featured_product.title }}</h2>
              <p class="av-product-card__desc">
                A clean, reliable daily product designed to become part of your routine.
              </p>
              <p class="av-product-card__price">{{ featured_product.price | money }}</p>
              <a href="{{ featured_product.url }}" class="av-btn av-btn--primary av-btn--full">
                View Product
              </a>
            {% else %}
              <p class="av-product-card__label">Our first product</p>
              <h2 class="av-product-card__title">Coming soon</h2>
              <p class="av-product-card__desc">
                Add a product to the avrrio-coffee collection to show it here automatically.
              </p>
            {% endif %}
          </div>
        </div>
      </div>
    </section>

    <section class="av-brand-grid">
      <article class="av-info-card">
        <h3 class="av-info-card__title">Why Avrrio</h3>
        <p class="av-info-card__text">
          We’re not launching with 20 products. We’re starting with one — and doing it right.
        </p>
      </article>

      <article class="av-info-card">
        <h3 class="av-info-card__title">Built for Repeat Customers</h3>
        <p class="av-info-card__text">
          Consistent quality, simple checkout, clean product design, and a product built to become part of a daily routine.
        </p>
      </article>

      <article class="av-info-card">
        <h3 class="av-info-card__title">This Is Just the Beginning</h3>
        <p class="av-info-card__text">
          Avrrio is being built as a clean, focused brand. One product today. A broader ecosystem tomorrow.
        </p>
      </article>
    </section>

  </div>
</main>
<main class="home">
  <section class="home-hero section-shell">
    <div class="home-hero__content">
      <img class="home-hero__logo" src="{{ 'avrrio-logo.png' | asset_url }}" alt="Avrrio Coffee logo">
      <p class="home-hero__eyebrow">Avrrio Coffee</p>
      <h1 class="home-hero__title">Simple. Strong. Daily Fuel.</h1>
      <p class="home-hero__copy">
        Avrrio starts with one thing: a dependable daily coffee.
        Clean, consistent, and built for people who value quality without complication.
      </p>

      <div class="home-hero__actions">
        <a href="/collections/avrrio-coffee" class="btn">Shop Coffee</a>
        {% if featured_product %}
          <a href="{{ featured_product.url }}" class="btn btn--secondary">View Product</a>
        {% endif %}
      </div>
    </div>

    <div class="home-hero__product-panel">
      <article class="product-card">
        {% if featured_product and featured_product.featured_image %}
          <a href="{{ featured_product.url }}" class="product-card__image-link">
<div class="home-hero">
  <div class="home-hero__content">
