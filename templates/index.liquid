{% assign featured_collection = collections['avrrio-coffee'] %}
{% assign featured_product = featured_collection.products.first %}
{% if featured_product == blank %}
  {% assign featured_product = all_products['avrrio-french-roast'] %}
{% endif %}

<section class="home-shell">
  <div class="container">

    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AVRRIO</p>
        <h1>Simple. Strong. Daily Fuel.</h1>
        <p class="hero-text">
          Avrrio starts with one thing done right — a dependable daily product.
          Clean, consistent, and built for people who value quality without complication.
        </p>

        <div class="hero-actions">
          <a href="/collections/avrrio-coffee" class="btn btn-primary">Shop</a>
          {% if featured_product %}
            <a href="{{ featured_product.url }}" class="btn btn-secondary">View Product</a>
          {% endif %}
        </div>
      </div>

      <div class="hero-card">
        <div class="hero-card-media">
          {% if featured_product and featured_product.featured_image %}
            <img
              src="{{ featured_product.featured_image | image_url: width: 1000 }}"
              alt="{{ featured_product.title | escape }}"
            >
          {% else %}
            <div class="media-placeholder">Product image</div>
          {% endif %}
        </div>

        <div class="hero-card-body">
          <p class="card-label">Our first product</p>

          {% if featured_product %}
            <h2>{{ featured_product.title }}</h2>
            <p class="card-text">
              A clean, reliable daily product designed to become part of your routine.
            </p>
            <p class="card-price">{{ featured_product.price | money }}</p>
            <a href="{{ featured_product.url }}" class="btn btn-primary btn-full">View Product</a>
          {% else %}
            <h2>Coming soon</h2>
            <p class="card-text">
              Add a product to the avrrio-coffee collection and it will appear here automatically.
            </p>
          {% endif %}
        </div>
      </div>
    </div>

  </div>
</section>
